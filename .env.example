# ===============================================
# قاعدة البيانات المحلية / Local Database (Development)
# ===============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=accounting_db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/accounting_db

# ===============================================
# Aiven PostgreSQL (Production)
# ===============================================
# استخدم هذه المتغيرات للاتصال بـ Aiven
# https://aiven.io/postgresql
AIVEN_HOST=your-instance.c.aivencloud.com
AIVEN_PORT=5432
AIVEN_USER=avnadmin
AIVEN_PASSWORD=your-secure-password
AIVEN_DB=defaultdb
AIVEN_SSL=require

# أو استخدم DATABASE_URL مباشرة:
# DATABASE_URL=postgresql://avnadmin:password@your-instance.c.aivencloud.com:5432/defaultdb?sslmode=require

# ===============================================
# Flask Configuration
# ===============================================
FLASK_ENV=production
FLASK_APP=run.py
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False

# ===============================================
# JWT Configuration
# ===============================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# ===============================================
# Vercel Configuration
# ===============================================
VERCEL_ENV=production
VERCEL_URL=https://your-domain.vercel.app
VERCEL_TOKEN=your-vercel-token

# ===============================================
# Email Configuration (اختياري)
# ===============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ===============================================
# Redis Configuration (اختياري)
# ===============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# ===============================================
# Application Settings
# ===============================================
APP_NAME=Accounting System
APP_VERSION=1.0.0
APP_DEBUG=False
APP_LOGGING_LEVEL=INFO

# ===============================================
# AI Configuration (اختياري)
# ===============================================
AI_ENABLED=true
ML_MODEL_PATH=/app/models

# ===============================================
# Security
# ===============================================
CORS_ORIGINS=http://localhost:3000,https://your-domain.com
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ===============================================
# Logging
# ===============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===============================================
# API Keys (اختياري)
# ===============================================
STRIPE_KEY=sk_test_...
PAYPAL_CLIENT_ID=...
